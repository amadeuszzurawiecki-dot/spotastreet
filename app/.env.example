# Spotastreet - Firebase Configuration Environment Variables
# Copy this file to .env or .env.local and fill in your real Google Firebase Web App credentials.
# You also need to add these key-value pairs to the environment variables settings in your Vercel project dashboard.

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=spotastreet-example.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=spotastreet-example
VITE_FIREBASE_STORAGE_BUCKET=spotastreet-example.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
